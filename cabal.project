packages:
  *.cabal

-- NeoHaskell core library
-- The git source is managed by flake.nix inputMap (nix flake update to update)
-- IMPORTANT: Use specific commit SHA, not branch name, for reproducible builds
-- To update: 1) nix flake lock --update-input neohaskell
--            2) Update the tag below to match: nix eval .#neohaskell.rev --raw
source-repository-package
  type: git
  location: https://github.com/neohaskell/neohaskell.git
  tag: e00b85637eddae5621c1a88e292b8311e599f288
  subdir: core


-- NeoHaskell integrations (OpenRouter, HTTP, etc.)
source-repository-package
  type: git
  location: https://github.com/neohaskell/neohaskell.git
  tag: e00b85637eddae5621c1a88e292b8311e599f288
  subdir: integrations




-- Version upper-bounds needed for compatibility with NeoHaskell core.
-- haskell.nix pins the Hackage snapshot, but these prevent picking API-breaking
-- versions that post-date the NeoHaskell core code at the pinned commit.
constraints:
  hasql < 1.10,
  opt-env-conf < 0.11